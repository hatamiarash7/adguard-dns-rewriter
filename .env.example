# AdGuard Home connection
ADGUARD_URL=http://192.168.1.1:3000
ADGUARD_USER=admin
ADGUARD_PASS=changeme

# IP address to use for DNS rewrite rules
REWRITE_IP=1.2.3.4

# URL of a plain-text file containing one domain per line
DOMAINS_URL=https://example.com/domains.txt

# Optional: dry-run mode (true/false, default: false)
DRY_RUN=false

# Optional: number of parallel workers (default: 10)
WORKERS=10
